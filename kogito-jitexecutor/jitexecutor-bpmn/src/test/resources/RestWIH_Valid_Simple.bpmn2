                   id="_RestWIHValidSimpleTest" 
                   targetNamespace="http://www.omg.org/bpmn20">
  <bpmn2:process id="RestWIHValidSimple" drools:packageName="com.example" drools:version="1.0" drools:adHoc="false" name="rest-wih-valid-simple" isExecutable="true" processType="Public">
    <bpmn2:startEvent id="_1" name="Start">
      <bpmn2:outgoing>_1-_2</bpmn2:outgoing>
    </bpmn2:startEvent>
