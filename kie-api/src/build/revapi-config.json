{
    "filters": {
        "revapi": {
            "java": {
                "filter": {
                    "packages": {
                        "regex": true,
                        "exclude": [
                            "org\\.kie\\.internal\\..*",
                            "org\\.kie\\.api\\.internal\\..*"
                        ]
                    },
                    "classes": {
                        "regex": true,
                        "exclude": []
                    }
                }
            }
        }
    },
    "checks": {
        "revapi": {
            "java": {
                "deprecation": {
                    "enabled": true,
                    "reportNewDeprecations": true
                }
            }
        }
    },
    "ignores": {
        "revapi": {
            "ignore": []
        }
    }
}

