<bpmn2:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn2="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:bpsim="http://www.bpsim.org/schemas/1.0" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:drools="http://www.jboss.org/drools" id="_multiGroupVarTest" xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL BPMN20.xsd http://www.jboss.org/drools drools.xsd http://www.bpsim.org/schemas/1.0 bpsim.xsd http://www.omg.org/spec/DD/20100524/DC DC.xsd http://www.omg.org/spec/DD/20100524/DI DI.xsd " exporter="jBPM Process Modeler" exporterVersion="2.0" targetNamespace="http://www.omg.org/bpmn20">
  <bpmn2:itemDefinition id="__MGV_Task_SkippableInputXItem" structureRef="Object"/>
  <bpmn2:itemDefinition id="__MGV_Task_TaskNameInputXItem" structureRef="Object"/>
  <bpmn2:itemDefinition id="__MGV_Task_GroupIdInputXItem" structureRef="Object"/>
  <bpmn2:itemDefinition id="_group1Item" structureRef="String"/>
  <bpmn2:itemDefinition id="_group2Item" structureRef="String"/>
  <bpmn2:itemDefinition id="_group3Item" structureRef="String"/>
  <bpmn2:collaboration id="_MGV_Collaboration" name="Default Collaboration">
    <bpmn2:participant id="_MGV_Participant" name="Pool Participant" processRef="manager_multiple_groups_variables"/>
  </bpmn2:collaboration>
  <bpmn2:process id="manager_multiple_groups_variables" drools:packageName="com.example" drools:version="1.0" drools:adHoc="false" name="manager_multiple_groups_variables" isExecutable="true" processType="Public">
    <bpmn2:property id="group1" itemSubjectRef="_group1Item" name="group1"/>
    <bpmn2:property id="group2" itemSubjectRef="_group2Item" name="group2"/>
    <bpmn2:property id="group3" itemSubjectRef="_group3Item" name="group3"/>
    <bpmn2:sequenceFlow id="_MGV_Flow2" sourceRef="_MGV_Task" targetRef="_MGV_End"/>
    <bpmn2:sequenceFlow id="_MGV_Flow1" sourceRef="_MGV_Start" targetRef="_MGV_Task"/>
    <bpmn2:endEvent id="_MGV_End">
      <bpmn2:incoming>_MGV_Flow2</bpmn2:incoming>
    </bpmn2:endEvent>
    <bpmn2:userTask id="_MGV_Task" name="Task">
      <bpmn2:extensionElements>
        <drools:metaData name="elementname">
          <drools:metaValue><![CDATA[Task]]></drools:metaValue>
        </drools:metaData>
      </bpmn2:extensionElements>
      <bpmn2:incoming>_MGV_Flow1</bpmn2:incoming>
      <bpmn2:outgoing>_MGV_Flow2</bpmn2:outgoing>
      <bpmn2:ioSpecification>
        <bpmn2:dataInput id="_MGV_Task_TaskNameInputX" drools:dtype="Object" itemSubjectRef="__MGV_Task_TaskNameInputXItem" name="TaskName"/>
        <bpmn2:dataInput id="_MGV_Task_SkippableInputX" drools:dtype="Object" itemSubjectRef="__MGV_Task_SkippableInputXItem" name="Skippable"/>
        <bpmn2:dataInput id="_MGV_Task_GroupIdInputX" drools:dtype="Object" itemSubjectRef="__MGV_Task_GroupIdInputXItem" name="GroupId"/>
        <bpmn2:inputSet>
          <bpmn2:dataInputRefs>_MGV_Task_TaskNameInputX</bpmn2:dataInputRefs>
          <bpmn2:dataInputRefs>_MGV_Task_SkippableInputX</bpmn2:dataInputRefs>
          <bpmn2:dataInputRefs>_MGV_Task_GroupIdInputX</bpmn2:dataInputRefs>
        </bpmn2:inputSet>
      </bpmn2:ioSpecification>
      <bpmn2:dataInputAssociation>
        <bpmn2:targetRef>_MGV_Task_TaskNameInputX</bpmn2:targetRef>
        <bpmn2:assignment>
          <bpmn2:from xsi:type="bpmn2:tFormalExpression"><![CDATA[Task]]></bpmn2:from>
          <bpmn2:to xsi:type="bpmn2:tFormalExpression"><![CDATA[_MGV_Task_TaskNameInputX]]></bpmn2:to>
        </bpmn2:assignment>
      </bpmn2:dataInputAssociation>
      <bpmn2:dataInputAssociation>
        <bpmn2:targetRef>_MGV_Task_SkippableInputX</bpmn2:targetRef>
        <bpmn2:assignment>
          <bpmn2:from xsi:type="bpmn2:tFormalExpression"><![CDATA[false]]></bpmn2:from>
          <bpmn2:to xsi:type="bpmn2:tFormalExpression"><![CDATA[_MGV_Task_SkippableInputX]]></bpmn2:to>
        </bpmn2:assignment>
      </bpmn2:dataInputAssociation>
      <bpmn2:dataInputAssociation>
        <bpmn2:targetRef>_MGV_Task_GroupIdInputX</bpmn2:targetRef>
        <bpmn2:assignment>
          <bpmn2:from xsi:type="bpmn2:tFormalExpression"><![CDATA[#{group1},#{group2},#{group3}]]></bpmn2:from>
          <bpmn2:to xsi:type="bpmn2:tFormalExpression"><![CDATA[_MGV_Task_GroupIdInputX]]></bpmn2:to>
        </bpmn2:assignment>
      </bpmn2:dataInputAssociation>
    </bpmn2:userTask>
    <bpmn2:startEvent id="_MGV_Start">
      <bpmn2:outgoing>_MGV_Flow1</bpmn2:outgoing>
    </bpmn2:startEvent>
  </bpmn2:process>
  <bpmndi:BPMNDiagram>
    <bpmndi:BPMNPlane bpmnElement="manager_multiple_groups_variables">
      <bpmndi:BPMNShape id="shape__MGV_Start" bpmnElement="_MGV_Start">
        <dc:Bounds height="56" width="56" x="100" y="100"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape__MGV_Task" bpmnElement="_MGV_Task">
        <dc:Bounds height="102" width="154" x="236" y="77"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape__MGV_End" bpmnElement="_MGV_End">
        <dc:Bounds height="56" width="56" x="470" y="100"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="edge_shape__MGV_Start_to_shape__MGV_Task" bpmnElement="_MGV_Flow1">
        <di:waypoint x="128" y="128"/>
        <di:waypoint x="236" y="128"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_shape__MGV_Task_to_shape__MGV_End" bpmnElement="_MGV_Flow2">
        <di:waypoint x="313" y="128"/>
        <di:waypoint x="498" y="128"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn2:definitions>

