[
  {
    "extension": "revapi.differences",
    "configuration": {
      "ignore": true,
      "differences": [
        {
          "code": "java.annotation.attributeAdded",
          "annotationType": "java.lang.Deprecated",
          "justification": "Adding version information (since/forRemoval attributes) to existing @Deprecated annotations is a documentation improvement that does not affect binary or source compatibility"
        }
      ]
    }
  },
  {
    "extension": "revapi.java",
    "configuration": {
      "filter": {
        "packages": {
          "regex": true,
          "exclude": [
            "org\\.kie\\.internal\\..*",
            "org\\.kie\\.api\\.internal\\..*"
          ]
        },
        "classes": {
          "regex": true,
          "exclude": []
        }
      }
    }
  },
  {
    "extension": "revapi.java",
    "id": "deprecation-check",
    "configuration": {
      "checks": {
        "deprecation": {
          "enabled": true,
          "reportNewDeprecations": false
        }
      }
    }
  }
]